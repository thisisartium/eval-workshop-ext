# Anthropic API Key (for Claude models like claude-sonnet-4-6)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# OpenAI API Key (for OpenAI models like gpt-4o-mini)
# Get yours at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-api-key-here

# OpenTelemetry Configuration (for tracing to CAT Cafe)
# These are the defaults - only uncomment if you need to override
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
